FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY brain.py config.py script_generator.py config.yaml ./
COPY tts/ tts/
COPY dashboard.html ./
COPY skills/ skills/

RUN mkdir -p /tmp/agent-radio

EXPOSE 8001

CMD ["python", "brain.py"]
